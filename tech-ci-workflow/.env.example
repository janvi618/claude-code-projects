# ===========================================
# Team Access (for private sharing)
# ===========================================
# Set this to require a password before accessing the app
# Leave commented out for open access
# TEAM_PASSWORD=your-shared-team-password

# Database (SQLite - no setup required)
DATABASE_URL="file:./dev.db"

# ===========================================
# LLM Configuration
# ===========================================

# MOCK_LLM=true  -> Uses deterministic mock responses (no API needed, fast)
# MOCK_LLM=false -> Real research mode (web search + LLM analysis)
MOCK_LLM=true

# LLM Provider: "anthropic" or "openai"
LLM_PROVIDER=anthropic

# For Anthropic Claude
ANTHROPIC_API_KEY=your-anthropic-key-here
LLM_MODEL=claude-sonnet-4-20250514

# For OpenAI (or OpenAI-compatible APIs)
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=your-openai-key-here
# LLM_MODEL=gpt-4

# ===========================================
# Research Mode Features (when MOCK_LLM=false)
# ===========================================
# - Web search using DuckDuckGo (no API key needed)
# - URL content extraction from your sources
# - Research-grade prompts for each step
# - Previous step context is passed forward
