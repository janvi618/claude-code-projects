{
  "name": "pomelli-clone",
  "version": "1.0.0",
  "description": "AI-powered brand marketing tool that extracts Brand DNA and generates campaigns",
  "main": "server/index.js",
  "type": "module",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "tsx server/index.ts",
    "client": "cd client && vite",
    "build": "cd client && vite build",
    "start": "npm run dev",
    "demo": "DEMO_MODE=true npm run dev",
    "install-all": "npm install && npm run install:client && npm run install:server",
    "install:client": "cd client && npm install",
    "install:server": "cd server && npm install"
  },
  "keywords": [
    "ai",
    "marketing",
    "brand",
    "social-media",
    "pomelli"
  ],
  "author": "Kilroy Software Factory",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12",
    "css": "^3.0.0",
    "openai": "^6.27.0"
  }
}
