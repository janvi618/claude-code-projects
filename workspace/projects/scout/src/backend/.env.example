# ─── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://scout:CHANGE_ME@db:5432/scout
POSTGRES_PASSWORD=CHANGE_ME

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── LLM API Keys ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...

# ─── Email (Resend) ────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=scout@yourdomain.com

# ─── Auth ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_32_BYTE_HEX_STRING
# AES-256 key for encrypting stored API keys (32 bytes, base64-encoded)
ENCRYPTION_KEY=CHANGE_ME_BASE64_ENCODED_32_BYTES
NEXTAUTH_SECRET=CHANGE_ME_NEXTAUTH_SECRET
NEXTAUTH_URL=https://yourdomain.com

# ─── App ───────────────────────────────────────────────────────────────────
FRONTEND_URL=https://yourdomain.com
ENVIRONMENT=production
ADMIN_EMAIL=admin@yourdomain.com
